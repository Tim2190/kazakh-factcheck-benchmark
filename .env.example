# Copy this file to .env and fill in your keys.  .env is git-ignored.
# Each model in scripts/models.json references one of these variable names.

# Google Gemini (https://ai.google.dev/)
GEMINI_API_KEY=

# DeepSeek (https://platform.deepseek.com/) — OpenAI-compatible
DEEPSEEK_API_KEY=

# Llama — via any OpenAI-compatible host (Together, Groq, OpenRouter, Fireworks…)
# Put the key of whichever provider you use here and set base_url in models.json.
LLAMA_API_KEY=

# Anthropic Claude (optional, if run via API instead of the blind subagent)
ANTHROPIC_API_KEY=
