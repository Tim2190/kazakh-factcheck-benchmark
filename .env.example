# Copy this file to .env and fill in your keys.  .env is git-ignored.
# Each model in scripts/models.json references one of these variable names.

# Google Gemini (https://ai.google.dev/) — the only model run via API.
# The other four (Claude, Qwen, DeepSeek, Kimi) are run via web chat.
GEMINI_API_KEY=

# Anthropic Claude (optional, if run via API instead of the blind subagent)
ANTHROPIC_API_KEY=
