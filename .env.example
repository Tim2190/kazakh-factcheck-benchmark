# Copy this file to .env and fill in your keys.  .env is git-ignored.
# Each model in scripts/models.json references one of these variable names.

# Google Gemini (https://ai.google.dev/)
GEMINI_API_KEY=

# Llama — served via Groq (https://console.groq.com/), OpenAI-compatible.
# Put your Groq key here; base_url/model are set in scripts/models.json.
LLAMA_API_KEY=

# Anthropic Claude (optional, if run via API instead of the blind subagent)
ANTHROPIC_API_KEY=
