[{"id":1,"russian_equivalent":"За двумя зайцами погонишься – ни одного не поймаешь"},{"id":2,"russian_equivalent":"Мастер слова / У него подвешенный язык"},{"id":3,"russian_equivalent":"Уносить ноги / Бежать без оглядки"},{"id":4,"russian_equivalent":"Мастер на все руки"},{"id":5,"russian_equivalent":"Простак / Доверчивый как дитя"},{"id":6,"russian_equivalent":"Потерять лицо / Репутация пошла прахом"},{"id":7,"russian_equivalent":"Водить за нос / Держать в дураках"},{"id":8,"russian_equivalent":"Петь дифирамбы"},{"id":9,"russian_equivalent":"Золотой голос"},{"id":10,"russian_equivalent":"Как сыр в масле кататься"},{"id":11,"russian_equivalent":"Чудо свершилось / Дождались светлого праздника"},{"id":12,"russian_equivalent":"Честный до мозга костей"},{"id":13,"russian_equivalent":"Носить на руках / Души не чаять"},{"id":14,"russian_equivalent":"Шумная ватага"},{"id":15,"russian_equivalent":"Нагнать страху / Вогнать в дрожь"},{"id":16,"russian_equivalent":"Отколотить до полусмерти / Измотать до изнеможения"},{"id":17,"russian_equivalent":"Быть наездником от Бога"},{"id":18,"russian_equivalent":"Прикусить язык / Воды в рот набрать"},{"id":19,"russian_equivalent":"Молчать как рыба / Набрал в рот воды"},{"id":20,"russian_equivalent":"Держать в ежовых рукавицах"},{"id":21,"russian_equivalent":"Задрать нос / Носа не чувствовать от гордости"},{"id":22,"russian_equivalent":"Разбежаться кто куда / Разлететься в разные стороны"},{"id":23,"russian_equivalent":"Локти кусать / Оставаться с носом"},{"id":24,"russian_equivalent":"По блату / Через заднюю дверь"},{"id":25,"russian_equivalent":"Закадычный друг / Неразлей вода"},{"id":26,"russian_equivalent":"Уводить разговор в сторону / Вставлять свои пять копеек"},{"id":27,"russian_equivalent":"Пытаться усидеть на двух стульях / Загнать себя в угол"},{"id":28,"russian_equivalent":"Улыбка до ушей / Сиять от счастья"},{"id":29,"russian_equivalent":"Кровь с молоком"},{"id":30,"russian_equivalent":"Не иметь ни копейки долга / Чист перед 